#!/bin/bash

# AsmFrameWork internal CLI
# Called via apm, not directly

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT_DIR="$(dirname "$SCRIPT_DIR")"
FW_DIR="$SCRIPT_DIR"
SRC_DIR="$ROOT_DIR/src"
OUT_DIR="$ROOT_DIR/.out"
EXAMPLE_DIR="$FW_DIR/example"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

cmd_init() {
    if [ -d "$SRC_DIR" ] && [ "$(ls -A "$SRC_DIR" 2>/dev/null)" ]; then
        echo -e "${YELLOW}src/ already exists and is not empty. Overwrite? [y/N]${NC}"
        read -rn1 answer
        echo
        [ "$answer" != "y" ] && [ "$answer" != "Y" ] && exit 0
        rm -rf "$SRC_DIR"
    fi

    cp -r "$EXAMPLE_DIR" "$SRC_DIR"
    echo -e "${GREEN}Project initialized in src/${NC}"
    echo -e "  src/main.asm"
    echo -e "  src/routes.asm"
    echo -e "  src/handlers/health.asm"
    echo -e ""
    echo -e "Run ${CYAN}apm build${NC} to build"
}

load_env() {
    if [ -f "$ROOT_DIR/.env" ]; then
        export $(grep -v '^#' "$ROOT_DIR/.env" | xargs)
    fi
}

cmd_build() {
    if [ ! -d "$SRC_DIR" ]; then
        echo -e "${RED}Error: src/ not found. Run apm init${NC}"
        exit 1
    fi

    echo -e "${CYAN}Building...${NC}"
    make -C "$FW_DIR" clean all --no-print-directory
    if [ $? -eq 0 ]; then
        echo -e "${GREEN}Done: .out/server${NC}"
    else
        echo -e "${RED}Build failed${NC}"
        exit 1
    fi
}

cmd_run() {
    cmd_build || exit 1
    load_env
    echo -e "${CYAN}Starting server...${NC}"
    "$OUT_DIR/server"
}

cmd_clean() {
    make -C "$FW_DIR" clean --no-print-directory
    echo -e "${GREEN}Cleaned${NC}"
}

cmd_debug() {
    if [ ! -d "$SRC_DIR" ]; then
        echo -e "${RED}Error: src/ not found. Run apm init${NC}"
        exit 1
    fi

    local extra_flags=""
    for arg in "$@"; do
        [ "$arg" = "--syscalls" ] && extra_flags="EXTRA_FLAGS=-DSYSCALL_DEBUG"
    done

    echo -e "${YELLOW}Debug build...${NC}"
    make -C "$FW_DIR" debug $extra_flags --no-print-directory
    if [ $? -eq 0 ]; then
        load_env
        echo -e "${CYAN}Running in debug mode...${NC}"
        "$OUT_DIR/server"
    else
        echo -e "${RED}Build failed${NC}"
        exit 1
    fi
}

case "${1:-}" in
    init)   cmd_init ;;
    build)  cmd_build ;;
    run)    cmd_run ;;
    clean)  cmd_clean ;;
    debug)  shift; cmd_debug "$@" ;;
    *)
        echo -e "${CYAN}AsmFrameWork CLI${NC}"
        echo ""
        echo "Commands:"
        echo "  init    Initialize project (create src/ from template)"
        echo "  build   Build project"
        echo "  run     Build and run"
        echo "  clean   Clean build"
        echo "  debug              Debug build and run (all logs)"
        echo "  debug --syscalls   Debug with syscall tracing"
        ;;
esac
